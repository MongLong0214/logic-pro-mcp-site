{
  "name": "logic-pro-mcp-site",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "dev": "WRANGLER_LOG_PATH=.wrangler/wrangler.log vinext dev",
    "build": "WRANGLER_LOG_PATH=.wrangler/wrangler.log vinext build",
    "start": "WRANGLER_LOG_PATH=.wrangler/wrangler.log vinext start",
    "test": "node scripts/run-tests.mjs",
    "lint": "eslint . --ignore-pattern dist --ignore-pattern .next",
    "typecheck": "tsc --noEmit",
    "verify:site": "node scripts/verify-site.mjs",
    "verify:all": "node scripts/verify-all.mjs",
    "verify:claims": "node --experimental-strip-types scripts/verify-claims.mjs",
    "verify:routes": "node scripts/verify-routes.mjs",
    "verify:links": "node scripts/verify-links.mjs",
    "verify:schema": "node scripts/verify-schema.mjs",
    "verify:security": "node scripts/verify-security.mjs",
    "verify:serp": "node scripts/verify-serp.mjs",
    "verify:bundle-privacy": "node scripts/verify-bundle-privacy.mjs",
    "verify:content-briefs": "node scripts/verify-content-briefs.mjs",
    "verify:lighthouse-evidence": "node scripts/verify-lighthouse-evidence.mjs",
    "verify:artifacts": "node scripts/verify-artifacts.mjs",
    "qa:secrets": "node scripts/scan-secrets.mjs",
    "qa:secretlint": "node scripts/qa-secretlint.mjs",
    "qa:react-doctor": "node scripts/qa-react-doctor.mjs",
    "qa:stability": "node scripts/qa-stability.mjs",
    "qa:release-evidence": "node --experimental-strip-types scripts/write-release-evidence.mjs",
    "qa:e2e": "node scripts/qa-e2e.mjs",
    "qa:lighthouse": "node scripts/qa-lighthouse.mjs",
    "evidence:release": "node --experimental-strip-types scripts/write-release-evidence.mjs",
    "verify:licenses": "node scripts/verify-production-licenses.mjs",
    "audit:prod": "npm audit --omit=dev --audit-level=high"
  },
  "dependencies": {
    "react": "19.2.6",
    "react-dom": "19.2.6"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "1.44.0",
    "@tailwindcss/postcss": "4.2.1",
    "@types/node": "22.19.19",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.3",
    "@vitejs/plugin-rsc": "0.5.27",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.10",
    "next": "16.2.10",
    "react-server-dom-webpack": "19.2.6",
    "tailwindcss": "4.2.1",
    "typescript": "5.9.3",
    "vinext": "0.0.50",
    "vite": "8.1.4",
    "wrangler": "4.110.0"
  },
  "overrides": {
    "@babel/core": "7.29.7",
    "js-yaml": "4.3.0",
    "postcss": "8.5.14"
  },
  "type": "module"
}
